{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "order": {
      "type": "number"
    },
    "tool": {
      "type": "string",
      "enum": [
        "claude-code",
        "opencode",
        "github-copilot",
        "all"
      ]
    },
    "difficulty": {
      "default": "beginner",
      "type": "string",
      "enum": [
        "beginner",
        "intermediate",
        "advanced"
      ]
    },
    "draft": {
      "default": false,
      "type": "boolean"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "order",
    "tool"
  ]
}