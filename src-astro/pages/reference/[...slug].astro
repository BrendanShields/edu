---
import { getCollection, render } from 'astro:content';
import ContentLayout from '../../layouts/ContentLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('reference');
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<ContentLayout title={entry.data.title} description={entry.data.description} section="Reference" sectionSlug="reference" tools={entry.data.tools} currentHref={`/reference/${entry.id}`}>
  <Content />
</ContentLayout>
