---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/navigation/Sidebar.astro';
import Card from '../../components/ui/Card.astro';
import CardGrid from '../../components/ui/CardGrid.astro';

const entries = await getCollection('advanced');
const sorted = entries.filter((e) => !e.data.draft).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Customization & Scale — Workshop">
  <Sidebar />
  <div id="main-content" class="transition-[margin-left] duration-200 ease-in-out" style="margin-left: var(--sidebar-width)">
    <main class="max-w-[var(--content-max-width)] mx-auto px-8 py-12">
      <div class="mb-10">
        <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-accent/15 text-accent mb-4 inline-block">Block 4 · Late Afternoon</span>
        <h1 class="text-4xl font-bold tracking-tight mb-3">Customization & Scale</h1>
        <p class="text-lg text-text-secondary">Make the tools work for your team and your projects.</p>
      </div>
      <CardGrid>
        {sorted.map((entry) => (
          <Card title={entry.data.title} description={entry.data.description} href={`/advanced/${entry.id}`} tools={entry.data.tools} />
        ))}
      </CardGrid>
    </main>
  </div>
</BaseLayout>
