---
// Default visual panel when no specific visual is defined
interface Props {
  title: string;
  tools: string[];
}

const { title, tools } = Astro.props;

const toolColors: Record<string, string> = {
  'claude-code': 'border-tool-claude/30 bg-tool-claude/5',
  'opencode': 'border-tool-opencode/30 bg-tool-opencode/5',
  'github-copilot': 'border-tool-copilot/30 bg-tool-copilot/5',
};

const toolDots: Record<string, string> = {
  'claude-code': 'bg-tool-claude',
  'opencode': 'bg-tool-opencode',
  'github-copilot': 'bg-tool-copilot',
};
---

<div class="space-y-6">
  <div class="p-8 rounded-2xl border border-border bg-surface/30 flex flex-col items-center justify-center min-h-[200px]">
    <div class="flex gap-2 mb-4">
      {tools.map((t) => (
        <span class:list={['w-3 h-3 rounded-full', toolDots[t] || 'bg-text-muted']}></span>
      ))}
    </div>
    <p class="text-sm text-text-muted text-center">{title}</p>
  </div>
</div>
