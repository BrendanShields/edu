---
// Simple flowchart / diagram container
interface Props {
  title?: string;
}
const { title } = Astro.props;
---
<div class="my-6 p-6 bg-surface rounded-xl border border-border">
  {title && (
    <p class="text-xs font-semibold uppercase tracking-wider text-text-muted mb-4">{title}</p>
  )}
  <div class="font-mono text-sm leading-loose text-text-secondary">
    <slot />
  </div>
</div>
