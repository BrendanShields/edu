---
// Hands-on exercise block
interface Props {
  label?: string;
}
const { label = 'Try it' } = Astro.props;
---
<div class="my-10 p-6 bg-accent/5 border border-accent/20 rounded-xl">
  <div class="flex items-center gap-2 mb-3">
    <span class="text-xs font-semibold uppercase tracking-wider text-accent">{label}</span>
    <span class="text-accent">👆</span>
  </div>
  <div class="text-base text-text-primary leading-relaxed">
    <slot />
  </div>
</div>
