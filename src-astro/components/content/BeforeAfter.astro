---
// Before/After comparison pair
interface Props {
  before?: string;
  after?: string;
}
const { before = 'Before', after = 'After' } = Astro.props;
---
<div class="my-8 grid grid-cols-1 gap-4">
  <div class="p-4 rounded-lg bg-red-500/5 border border-red-500/20">
    <span class="text-[10px] font-semibold uppercase tracking-wider text-red-400 mb-2 block">{before}</span>
    <div class="text-sm text-text-secondary">
      <slot name="before" />
    </div>
  </div>
  <div class="p-4 rounded-lg bg-green-500/5 border border-green-500/20">
    <span class="text-[10px] font-semibold uppercase tracking-wider text-green-400 mb-2 block">{after}</span>
    <div class="text-sm text-text-secondary">
      <slot name="after" />
    </div>
  </div>
</div>
