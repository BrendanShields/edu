---
// Styled terminal mockup
interface Props {
  title?: string;
}
const { title = 'Terminal' } = Astro.props;
---
<div class="my-4 rounded-xl overflow-hidden border border-border bg-[#0d1117]">
  <div class="flex items-center gap-2 px-4 py-2.5 bg-[#161b22] border-b border-border">
    <div class="flex gap-1.5">
      <span class="w-3 h-3 rounded-full bg-[#ff5f57]"></span>
      <span class="w-3 h-3 rounded-full bg-[#febc2e]"></span>
      <span class="w-3 h-3 rounded-full bg-[#28c840]"></span>
    </div>
    <span class="text-xs text-text-muted ml-2">{title}</span>
  </div>
  <div class="p-4 font-mono text-sm leading-relaxed text-[#e6edf3] overflow-x-auto">
    <slot />
  </div>
</div>
