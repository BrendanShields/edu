---
interface Props {
  section: string;
  sectionSlug: string;
  title: string;
}

const { section, sectionSlug, title } = Astro.props;
---

<nav class="flex items-center gap-2 text-sm text-text-muted mb-8">
  <a href="/" class="hover:text-text-secondary transition-colors">Home</a>
  <span>/</span>
  <a href={`/${sectionSlug}`} class="hover:text-text-secondary transition-colors">{section}</a>
  <span>/</span>
  <span class="text-text-secondary">{title}</span>
</nav>
