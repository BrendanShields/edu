---
import { getPrevNext } from '../../lib/navigation';

interface Props {
  currentHref: string;
}

const { currentHref } = Astro.props;
const { prev, next } = await getPrevNext(currentHref);
---

<nav class="flex items-center justify-between mt-16 pt-8 border-t border-border">
  {prev ? (
    <a href={prev.href} class="group flex flex-col gap-1 text-left">
      <span class="text-xs text-text-muted uppercase tracking-wider">Previous</span>
      <span class="text-sm text-text-secondary group-hover:text-accent transition-colors flex items-center gap-2">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M19 12H5M12 19l-7-7 7-7" />
        </svg>
        {prev.title}
      </span>
    </a>
  ) : <div />}

  {next ? (
    <a href={next.href} class="group flex flex-col gap-1 text-right ml-auto">
      <span class="text-xs text-text-muted uppercase tracking-wider">Next</span>
      <span class="text-sm text-text-secondary group-hover:text-accent transition-colors flex items-center gap-2">
        {next.title}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M12 5l7 7-7 7" />
        </svg>
      </span>
    </a>
  ) : <div />}
</nav>
