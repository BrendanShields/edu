---
import type { NavItem } from '../../lib/navigation';

interface Props {
  item: NavItem;
  isActive: boolean;
}

const { item, isActive } = Astro.props;

const toolDotColors: Record<string, string> = {
  'claude-code': 'bg-tool-claude',
  'opencode': 'bg-tool-opencode',
  'github-copilot': 'bg-tool-copilot',
};

const isAllTools = item.tools.length === 3;
---

<li>
  <a
    href={item.href}
    class:list={[
      'flex items-center gap-3 px-6 py-1.5 text-sm transition-colors relative',
      isActive
        ? 'text-text-primary bg-surface'
        : 'text-text-secondary hover:text-text-primary hover:bg-surface-hover',
    ]}
  >
    {isActive && (
      <span class="absolute left-0 top-1/2 -translate-y-1/2 w-0.5 h-4 bg-accent rounded-r"></span>
    )}
    <span class="flex gap-0.5 flex-shrink-0">
      {isAllTools ? (
        <span class="w-1.5 h-1.5 rounded-full bg-text-muted"></span>
      ) : (
        item.tools.map((t) => (
          <span class:list={['w-1.5 h-1.5 rounded-full', toolDotColors[t] || 'bg-text-muted']}></span>
        ))
      )}
    </span>
    <span class="truncate">{item.title}</span>
  </a>
</li>
