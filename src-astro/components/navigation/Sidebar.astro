---
import { getNavigation } from '../../lib/navigation';
import SidebarSection from './SidebarSection.astro';
import SidebarToggle from './SidebarToggle.tsx';

const navigation = await getNavigation();
const currentPath = Astro.url.pathname;
---

<aside
  id="sidebar"
  class="fixed top-0 left-0 z-40 h-screen w-[var(--sidebar-width)] bg-background border-r border-border overflow-y-auto transition-transform duration-200 ease-in-out"
>
  <div class="flex flex-col h-full">
    <!-- Logo / Home -->
    <a href="/" class="flex items-center gap-3 px-6 py-6 border-b border-border hover:bg-surface transition-colors">
      <div class="w-3 h-3 rounded-full bg-accent flex-shrink-0"></div>
      <span class="font-semibold text-sm tracking-tight">AI Coding Workshop</span>
    </a>

    <!-- Navigation -->
    <nav class="flex-1 overflow-y-auto py-4">
      {navigation.map((section) => (
        <SidebarSection section={section} currentPath={currentPath} />
      ))}
    </nav>

    <!-- Footer -->
    <div class="px-6 py-4 border-t border-border">
      <p class="text-xs text-text-muted">Press <kbd class="px-1.5 py-0.5 bg-surface rounded text-[10px] border border-border">S</kbd> to toggle sidebar</p>
    </div>
  </div>
</aside>

<!-- Toggle button (visible when sidebar is hidden) -->
<SidebarToggle client:load />
