---
import type { NavSection } from '../../lib/navigation';
import SidebarLink from './SidebarLink.astro';

interface Props {
  section: NavSection;
  currentPath: string;
}

const { section, currentPath } = Astro.props;
const isActive = currentPath.startsWith(`/${section.slug}`);
---

<div class="mb-2">
  <a
    href={`/${section.slug}`}
    class:list={[
      'flex items-center justify-between px-6 py-2 text-xs font-semibold uppercase tracking-wider',
      isActive ? 'text-accent' : 'text-text-muted hover:text-text-secondary',
    ]}
  >
    <span class="flex items-center gap-2">
      <span>{section.title}</span>
      {section.label !== 'Reference' && (
        <span class="text-[9px] font-normal normal-case tracking-normal text-text-muted">({section.label})</span>
      )}
    </span>
    <span class="text-[10px]">{section.items.length}</span>
  </a>
  <ul class="space-y-0.5">
    {section.items.map((item) => (
      <SidebarLink item={item} isActive={currentPath === item.href || currentPath === `${item.href}/`} />
    ))}
  </ul>
</div>
