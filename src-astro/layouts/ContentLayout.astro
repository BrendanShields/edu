---
import BaseLayout from './BaseLayout.astro';
import Sidebar from '../components/navigation/Sidebar.astro';
import Breadcrumbs from '../components/navigation/Breadcrumbs.astro';
import PrevNext from '../components/navigation/PrevNext.astro';
import KeyboardNav from '../components/navigation/KeyboardNav.tsx';
import { getPrevNext } from '../lib/navigation';

interface Props {
  title: string;
  description: string;
  section: string;
  sectionSlug: string;
  tools: string[];
  currentHref: string;
}

const { title, description, section, sectionSlug, tools, currentHref } = Astro.props;
const { prev, next } = await getPrevNext(currentHref);

const toolLabels: Record<string, string> = {
  'claude-code': 'Claude Code',
  'opencode': 'OpenCode',
  'github-copilot': 'GitHub Copilot',
};

const toolColors: Record<string, string> = {
  'claude-code': 'bg-tool-claude/20 text-tool-claude',
  'opencode': 'bg-tool-opencode/20 text-tool-opencode',
  'github-copilot': 'bg-tool-copilot/20 text-tool-copilot',
};

const isAllTools = tools.length === 3;
---

<BaseLayout title={`${title} — Workshop`} description={description}>
  <Sidebar />

  <div id="main-content" class="transition-[margin-left] duration-200 ease-in-out" style="margin-left: var(--sidebar-width)">
    <main class="max-w-[var(--content-max-width)] mx-auto px-8 py-12">
      <Breadcrumbs section={section} sectionSlug={sectionSlug} title={title} />

      <div class="mb-8">
        <div class="flex items-center gap-2 mb-3 flex-wrap">
          {isAllTools ? (
            <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-text-muted/20 text-text-secondary">All Tools</span>
          ) : (
            tools.map((t) => (
              <span class:list={['text-xs font-medium px-2.5 py-1 rounded-full', toolColors[t]]}>
                {toolLabels[t]}
              </span>
            ))
          )}
        </div>
        <h1 class="text-4xl font-bold tracking-tight">{title}</h1>
        <p class="text-lg text-text-secondary mt-3">{description}</p>
      </div>

      <article class="prose prose-lg max-w-none">
        <slot />
      </article>

      <PrevNext currentHref={currentHref} />
    </main>
  </div>

  <KeyboardNav client:idle prevHref={prev?.href} nextHref={next?.href} />
</BaseLayout>
