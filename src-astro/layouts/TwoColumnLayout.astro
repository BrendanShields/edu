---
import BaseLayout from './BaseLayout.astro';
import Sidebar from '../components/navigation/Sidebar.astro';
import Breadcrumbs from '../components/navigation/Breadcrumbs.astro';
import PrevNext from '../components/navigation/PrevNext.astro';
import KeyboardNav from '../components/navigation/KeyboardNav.tsx';
import { getPrevNext } from '../lib/navigation';

interface Props {
  title: string;
  description: string;
  section: string;
  sectionSlug: string;
  tools: string[];
  currentHref: string;
}

const { title, description, section, sectionSlug, tools, currentHref } = Astro.props;
const { prev, next } = await getPrevNext(currentHref);

const toolLabels: Record<string, string> = {
  'claude-code': 'Claude Code',
  'opencode': 'OpenCode',
  'github-copilot': 'GitHub Copilot',
};

const toolColors: Record<string, string> = {
  'claude-code': 'bg-tool-claude/20 text-tool-claude',
  'opencode': 'bg-tool-opencode/20 text-tool-opencode',
  'github-copilot': 'bg-tool-copilot/20 text-tool-copilot',
};

const isAllTools = tools.length === 3;
---

<BaseLayout title={`${title} — Workshop`} description={description}>
  <Sidebar />

  <div id="main-content" class="transition-[margin-left] duration-200 ease-in-out" style="margin-left: var(--sidebar-width)">
    <!-- Header -->
    <div class="px-8 pt-8 pb-0">
      <Breadcrumbs section={section} sectionSlug={sectionSlug} title={title} />
    </div>

    <!-- Two column grid -->
    <div class="flex min-h-[calc(100vh-80px)]">
      <!-- Left: Narrative -->
      <div class="flex-1 max-w-[640px] px-8 py-6">
        <div class="mb-10">
          <div class="flex items-center gap-2 mb-4 flex-wrap">
            {isAllTools ? (
              <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-text-muted/20 text-text-secondary">All Tools</span>
            ) : (
              tools.map((t) => (
                <span class:list={['text-xs font-medium px-2.5 py-1 rounded-full', toolColors[t]]}>
                  {toolLabels[t]}
                </span>
              ))
            )}
          </div>
        </div>

        <article class="dd-prose">
          <slot />
        </article>

        <PrevNext currentHref={currentHref} />
      </div>

      <!-- Right: Visual Panel (sticky) -->
      <div class="hidden lg:block flex-1 max-w-[480px] border-l border-border">
        <div class="sticky top-0 h-screen overflow-y-auto p-8 flex items-start justify-center">
          <div class="w-full pt-12">
            <slot name="visual" />
          </div>
        </div>
      </div>
    </div>
  </div>

  <KeyboardNav client:idle prevHref={prev?.href} nextHref={next?.href} />
</BaseLayout>

<style is:global>
  /* DD-style prose: generous spacing, conversational feel */
  .dd-prose h1 {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
    color: var(--color-text-primary);
  }

  .dd-prose h2 {
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: 3.5rem;
    margin-bottom: 1rem;
    color: var(--color-text-primary);
  }

  .dd-prose h3 {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    margin-top: 4rem;
    margin-bottom: 1.5rem;
  }

  .dd-prose p {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--color-text-primary);
    margin-bottom: 1.5rem;
    max-width: 560px;
  }

  .dd-prose ul, .dd-prose ol {
    margin-bottom: 1.5rem;
    padding-left: 1.25rem;
  }

  .dd-prose li {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--color-text-primary);
    margin-bottom: 0.5rem;
  }

  .dd-prose strong {
    color: var(--color-text-primary);
    font-weight: 600;
  }

  .dd-prose a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .dd-prose blockquote {
    border-left: 2px solid var(--color-accent);
    padding-left: 1.25rem;
    margin: 2rem 0;
    font-style: italic;
    color: var(--color-text-secondary);
  }

  .dd-prose pre {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.25rem;
    margin: 2rem 0;
    overflow-x: auto;
    font-size: 0.875rem;
    line-height: 1.6;
  }

  .dd-prose code:not(pre code) {
    background: var(--color-surface);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.875em;
    border: 1px solid var(--color-border);
    color: var(--color-accent);
  }

  .dd-prose table {
    width: 100%;
    margin: 2rem 0;
    font-size: 0.875rem;
    border-collapse: collapse;
  }

  .dd-prose th {
    text-align: left;
    padding: 0.75rem;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text-muted);
    font-weight: 500;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .dd-prose td {
    padding: 0.75rem;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text-secondary);
  }

  .dd-prose hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 3rem 0;
  }
</style>
